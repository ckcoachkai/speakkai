---
interface Props {
  id?: string;
  variant?: "strip" | "page";
}

const { id, variant = "strip" } = Astro.props;
---

<section class:list={["contact-strip", { "is-page": variant === "page" }]} id={id} aria-label="Contact Coach Kai">
  <div class="contact-inner">
    <div class="contact-qr-wrap">
      <img
        class="contact-qr"
        src="/images/coach-kai-wechat-qr.png"
        width="938"
        height="1340"
        alt="Coach Kai WeChat QR code"
      />
    </div>
    <div class="contact-copy">
      {variant === "page" ? <h1>Contact Coach Kai</h1> : <strong>Contact Coach Kai</strong>}
      <span>WeChat: <b>CKcoachkai</b></span>
      <span>小红书: <b>CKcoachkai</b></span>
    </div>
  </div>
</section>

<style>
  .contact-strip {
    display: flex;
    height: 96px;
    border-bottom: 1px solid #d5deed;
    background: #f4f8fd;
  }

  .contact-inner {
    display: flex;
    width: min(100% - 32px, 1120px);
    height: 100%;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin: 0 auto;
  }

  .contact-qr-wrap {
    position: relative;
    width: 76px;
    height: 76px;
    flex: 0 0 76px;
    overflow: hidden;
    border: 1px solid #c7d4e5;
    border-radius: 4px;
    background: #fff;
  }

  .contact-qr {
    position: absolute;
    top: -68.33%;
    left: -28.33%;
    display: block;
    width: 156.33%;
    max-width: none;
    height: auto;
  }

  .contact-copy {
    display: grid;
    gap: 2px;
    color: #40546f;
    font-size: 12px;
    line-height: 1.25;
  }

  .contact-copy strong {
    margin-bottom: 2px;
    color: #102c54;
    font-size: 14px;
  }

  .contact-copy h1 {
    margin: 0 0 8px;
    color: #102c54;
    font-size: clamp(32px, 5vw, 52px);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .contact-copy b {
    color: #152f55;
    font-weight: 850;
  }

  .contact-strip.is-page {
    min-height: calc(100vh - 62px);
    height: auto;
    border-bottom: 0;
  }

  .is-page .contact-inner {
    justify-content: center;
    gap: clamp(28px, 6vw, 72px);
    padding: 48px 0;
  }

  .is-page .contact-qr-wrap {
    width: min(34vw, 320px);
    height: min(34vw, 320px);
    flex-basis: min(34vw, 320px);
    border-color: #afc1d7;
    box-shadow: 0 14px 34px rgb(28 58 91 / 12%);
  }

  .is-page .contact-copy {
    gap: 9px;
    font-size: 18px;
  }

  @media (max-width: 640px) {
    .contact-strip { height: 88px; }

    .contact-inner {
      width: min(100% - 20px, 420px);
      justify-content: center;
      gap: 10px;
    }

    .contact-qr-wrap {
      width: 68px;
      height: 68px;
      flex-basis: 68px;
    }

    .contact-copy { font-size: 11px; }
    .contact-copy strong { font-size: 13px; }

    .contact-strip.is-page { min-height: calc(100vh - 52px); }

    .is-page .contact-inner {
      width: min(100% - 32px, 420px);
      flex-direction: column;
      gap: 24px;
      padding: 36px 0 54px;
      text-align: center;
    }

    .is-page .contact-qr-wrap {
      width: min(74vw, 280px);
      height: min(74vw, 280px);
      flex-basis: min(74vw, 280px);
    }

    .is-page .contact-copy { font-size: 16px; }
  }
</style>
