---
import { ChevronsDown, ChevronsUp } from "@lucide/astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  pageTitle: string;
  description: string;
  toolTitle: string;
  toolSrc: string;
}

const { pageTitle, description, toolTitle, toolSrc } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <style>
      :global(*) { box-sizing: border-box; }

      :global(html),
      :global(body) {
        width: 100%;
        min-width: 320px;
        height: 100%;
        margin: 0;
      }

      :global(body) {
        overflow: hidden;
        background: #090d14;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      .site-header {
        position: relative;
        z-index: 10;
        display: flex;
        min-height: 48px;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .site-nav {
        display: flex;
        width: min(100% - 80px, 720px);
        align-items: center;
        justify-content: center;
        gap: clamp(18px, 3.5vw, 44px);
      }

      .site-nav a {
        padding: 14px 4px 12px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      .nav-toggle {
        position: absolute;
        right: 12px;
        display: inline-grid;
        width: 32px;
        height: 32px;
        place-items: center;
        border: 1px solid #c7d3e5;
        border-radius: 5px;
        background: #fff;
        color: #173d70;
        cursor: pointer;
      }

      .nav-toggle:hover { background: #eef5ff; }

      .nav-toggle:focus-visible {
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      .expand-icon { display: none; }

      .tool-frame {
        display: block;
        width: 100%;
        height: calc(100vh - 74px);
        height: calc(100dvh - 74px);
        border: 0;
        background: #090d14;
      }

      :global(body.nav-collapsed) .site-header { min-height: 28px; }
      :global(body.nav-collapsed) .site-nav { display: none; }
      :global(body.nav-collapsed) .nav-toggle {
        right: 8px;
        width: 26px;
        height: 24px;
      }
      :global(body.nav-collapsed) .collapse-icon { display: none; }
      :global(body.nav-collapsed) .expand-icon { display: block; }
      :global(body.nav-collapsed) .tool-frame {
        height: calc(100vh - 54px);
        height: calc(100dvh - 54px);
      }

      @media (max-width: 640px) {
        .site-header { min-height: 46px; }

        .site-nav {
          width: calc(100% - 42px);
          margin-right: 42px;
          gap: 0;
        }

        .site-nav a {
          flex: 1 1 16.666%;
          padding: 13px 1px 11px;
          font-size: clamp(9.5px, 2.8vw, 12px);
          text-align: center;
        }

        .nav-toggle { right: 7px; width: 30px; height: 30px; }

        .tool-frame {
          height: calc(100vh - 72px);
          height: calc(100dvh - 72px);
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/schedule/">Schedule</a>
        <a href="/resources/" aria-current="page">Resources</a>
        <a href="/contact/">Contact</a>
      </nav>
      <button
        class="nav-toggle"
        type="button"
        aria-label="Hide navigation"
        aria-expanded="true"
        title="Hide navigation"
      >
        <ChevronsUp class="collapse-icon" size={18} stroke-width={2.2} aria-hidden="true" />
        <ChevronsDown class="expand-icon" size={18} stroke-width={2.2} aria-hidden="true" />
      </button>
    </header>
    <iframe
      class="tool-frame"
      src={toolSrc}
      title={toolTitle}
      allow="autoplay"
    ></iframe>
    <SiteFooter />
    <script>
      const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");

      toggle?.addEventListener("click", () => {
        const collapsed = document.body.classList.toggle("nav-collapsed");
        toggle.setAttribute("aria-expanded", String(!collapsed));
        toggle.setAttribute("aria-label", collapsed ? "Show navigation" : "Hide navigation");
        toggle.title = collapsed ? "Show navigation" : "Hide navigation";
      });
    </script>
  </body>
</html>
