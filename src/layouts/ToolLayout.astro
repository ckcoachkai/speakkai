---
import ContactStrip from "../components/ContactStrip.astro";

interface Props {
  pageTitle: string;
  description: string;
  toolTitle: string;
  toolSrc: string;
}

const { pageTitle, description, toolTitle, toolSrc } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <style>
      :global(*) { box-sizing: border-box; }

      :global(html),
      :global(body) {
        width: 100%;
        min-width: 320px;
        height: 100%;
        margin: 0;
      }

      :global(body) {
        overflow: hidden;
        background: #090d14;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      .site-header {
        position: relative;
        z-index: 10;
        display: flex;
        min-height: 62px;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .site-nav {
        display: flex;
        width: min(100%, 620px);
        align-items: center;
        justify-content: center;
        gap: clamp(18px, 3.5vw, 44px);
      }

      .site-nav a {
        padding: 21px 4px 19px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      .tool-frame {
        display: block;
        width: 100%;
        height: calc(100vh - 158px);
        height: calc(100dvh - 158px);
        border: 0;
        background: #090d14;
      }

      @media (max-width: 640px) {
        .site-header { min-height: 52px; }

        .site-nav {
          width: 100%;
          gap: 0;
        }

        .site-nav a {
          flex: 1 1 20%;
          padding: 18px 2px 16px;
          font-size: 14px;
          text-align: center;
        }

        .tool-frame {
          height: calc(100vh - 140px);
          height: calc(100dvh - 140px);
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/#about">About</a>
        <a href="/schedule/">Schedule</a>
        <a href="/tools/" aria-current="page">Tools</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>
    <ContactStrip />
    <iframe
      class="tool-frame"
      src={toolSrc}
      title={toolTitle}
      allow="autoplay"
    ></iframe>
  </body>
</html>
