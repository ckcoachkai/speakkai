---
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  pageTitle: string;
  description: string;
}

const { pageTitle, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <style>
      :global(*) { box-sizing: border-box; }

      :global(html) {
        min-width: 320px;
        min-height: 100%;
        background: #f4f7fb;
        color: #14233b;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      :global(body) {
        display: flex;
        min-height: 100vh;
        margin: 0;
        flex-direction: column;
      }

      .site-header {
        display: flex;
        min-height: 48px;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .site-nav {
        display: flex;
        width: min(100%, 720px);
        align-items: center;
        justify-content: center;
        gap: clamp(14px, 2.8vw, 38px);
      }

      .site-nav a {
        padding: 14px 3px 12px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      main {
        width: min(100% - 40px, 1120px);
        margin: 0 auto;
        flex: 1 0 auto;
        padding: clamp(34px, 6vw, 68px) 0 72px;
      }

      @media (max-width: 700px) {
        .site-header { min-height: 46px; }
        .site-nav { width: 100%; gap: 0; }
        .site-nav a {
          flex: 1 1 16.666%;
          padding: 13px 1px 11px;
          font-size: clamp(10px, 3.2vw, 13px);
          text-align: center;
        }
        main { width: min(100% - 28px, 620px); padding-top: 32px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/about/">About</a>
        <a href="/schedule/">Schedule</a>
        <a href="/resources/" aria-current="page">Resources</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
