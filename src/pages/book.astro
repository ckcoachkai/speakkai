---
import { ArrowLeft, CalendarCheck, Clock, Globe, LockKeyhole, Mail, UserRound } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import TopLinks from "@/components/TopLinks.astro";
---

<BaseLayout
  title="Book a Time | Speaking With Kai"
  description="Book an available consultation or coaching time with Speaking With Kai."
>
  <main>
    <section class="booking-shell" aria-labelledby="booking-title">
      <header class="site-nav" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="Speaking With Kai home">SWK</a>
        <nav>
          <a href="/">Home</a>
          <a href="/about-kai/">About Kai</a>
          <a href="/corporate-events/">Corporate Events</a>
          <a href="/book/">Book</a>
          <a href="/#blog">Blog</a>
        </nav>
        <a class="nav-cta" href="/admin/">
          Admin
          <LockKeyhole aria-hidden="true" size={18} />
        </a>
      </header>
      <TopLinks />

      <div class="booking-hero">
        <a class="back-link" href="/">
          <ArrowLeft aria-hidden="true" size={18} />
          Home
        </a>
        <p class="eyebrow">Booking</p>
        <h1 id="booking-title">Book a speaking support time.</h1>
        <p>
          Choose an open time, leave your contact details, and Kai will confirm the session.
        </p>
      </div>

      <div class="booking-grid">
        <section class="booking-panel" aria-labelledby="identity-title">
          <div class="panel-heading">
            <UserRound aria-hidden="true" />
            <div>
              <p class="eyebrow">Sign in</p>
              <h2 id="identity-title">Your details</h2>
            </div>
          </div>
          <form id="booking-profile-form" class="booking-form">
            <label>
              Name
              <input id="booking-name" name="name" autocomplete="name" required />
            </label>
            <label>
              Email
              <input id="booking-email" name="email" type="email" autocomplete="email" required />
            </label>
            <button class="button button-light" type="submit">
              Save details
              <Mail aria-hidden="true" size={18} />
            </button>
          </form>
        </section>

        <section class="booking-panel booking-panel-wide" aria-labelledby="slots-title">
          <div class="panel-heading">
            <CalendarCheck aria-hidden="true" />
            <div>
              <p class="eyebrow">Available times</p>
              <h2 id="slots-title">Open slots</h2>
            </div>
          </div>
          <div class="booking-filters" aria-label="Booking filters">
            <button class="filter-pill is-active" type="button" data-filter="all">All</button>
            <button class="filter-pill" type="button" data-filter="online">Online</button>
            <button class="filter-pill" type="button" data-filter="in-person">In person</button>
          </div>
          <div id="slot-list" class="slot-list" aria-live="polite"></div>
        </section>

        <aside class="booking-panel booking-summary" aria-labelledby="summary-title">
          <div class="panel-heading">
            <Clock aria-hidden="true" />
            <div>
              <p class="eyebrow">Status</p>
              <h2 id="summary-title">Booking summary</h2>
            </div>
          </div>
          <div id="booking-summary" class="summary-box">
            <p>Select a time to begin.</p>
          </div>
          <div class="china-note">
            <Globe aria-hidden="true" />
            <span>Built without Google Calendar or Google sign-in.</span>
          </div>
        </aside>
      </div>
    </section>
  </main>
  <SiteFooter />
  <script is:inline type="module" src="/scripts/booking.js"></script>
</BaseLayout>
