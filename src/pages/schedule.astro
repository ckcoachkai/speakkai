---
import { RefreshCw } from "@lucide/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta name="color-scheme" content="light" />
    <title>Coach Kai's Timeslot | SpeakKai</title>
    <style is:global>
      :root {
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", "Microsoft YaHei", sans-serif;
        color: #17233d;
        background: #f4f7fb;
        font-synthesis: none;
      }

      * { box-sizing: border-box; }

      body {
        min-width: 320px;
        min-height: 100vh;
        margin: 0;
        background: #f4f7fb;
      }

      button, a { font: inherit; }

      .coach-banner {
        position: relative;
        width: 100%;
        height: auto;
        aspect-ratio: 4 / 1;
        overflow: hidden;
        border-bottom: 1px solid #224d83;
        background: #06142f;
      }

      .coach-banner picture {
        display: block;
        width: 100%;
        height: 100%;
      }

      .coach-banner img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }

      .banner-socials {
        position: absolute;
        right: clamp(14px, 3vw, 44px);
        bottom: 14px;
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 8px 12px;
        border-left: 3px solid #36b8ff;
        border-radius: 4px;
        color: #fff;
        background: rgb(3 15 42 / 82%);
        font-size: 13px;
        line-height: 1.2;
        text-shadow: 0 1px 3px rgb(0 0 0 / 55%);
      }

      .banner-socials strong { font-weight: 800; }

      .page-header {
        display: grid;
        grid-template-columns: minmax(220px, 1fr) auto minmax(44px, 1fr);
        min-height: 60px;
        align-items: center;
        gap: 20px;
        padding: 9px clamp(14px, 2.5vw, 36px);
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .identity { min-width: 0; }

      .identity h1 {
        margin: 0;
        font-size: 18px;
        font-weight: 760;
        letter-spacing: 0;
      }

      .identity p {
        margin: 3px 0 0;
        color: #65718a;
        font-size: 11px;
      }

      .site-nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: clamp(18px, 3vw, 42px);
      }

      .site-nav a {
        padding: 16px 4px 14px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      .refresh-button {
        display: inline-grid;
        width: 36px;
        height: 36px;
        justify-self: end;
        place-items: center;
        border: 1px solid #c7d3e5;
        border-radius: 6px;
        color: #173d70;
        background: #fff;
        cursor: pointer;
      }

      .refresh-button:hover { background: #eef5ff; }

      .refresh-button:focus-visible,
      .sheet-tab:focus-visible {
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      main { padding: 12px clamp(10px, 1.7vw, 26px) 20px; }

      .schedule-toolbar {
        display: flex;
        min-height: 40px;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 8px;
      }

      .month-heading {
        margin: 0;
        padding-bottom: 5px;
        font-size: 20px;
        font-weight: 780;
        letter-spacing: 0;
      }

      .sheet-tabs {
        display: flex;
        gap: 2px;
        overflow-x: auto;
        scrollbar-width: thin;
      }

      .sheet-tab {
        position: relative;
        min-width: max-content;
        padding: 8px 12px 9px;
        border: 1px solid #cbd6e7;
        border-bottom: 0;
        color: #65718a;
        background: transparent;
        cursor: pointer;
      }

      .sheet-tab[aria-selected="true"] {
        color: #173d70;
        font-weight: 720;
        background: #fff;
      }

      .sheet-tab[aria-selected="true"]::after {
        position: absolute;
        right: 8px;
        bottom: 0;
        left: 8px;
        height: 3px;
        background: #17a6a0;
        content: "";
      }

      .calendar-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(230px, 18vw);
        gap: 10px;
        align-items: stretch;
      }

      .table-shell {
        min-width: 0;
        overflow: hidden;
        border: 2px solid #244f83;
        background: #fff;
      }

      table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        table-layout: fixed;
      }

      th, td {
        border: 1px solid #9eb0c8;
      }

      th:last-child, td:last-child { border-right: 0; }
      tbody tr:last-child td { border-bottom: 0; }

      th {
        height: 29px;
        padding: 4px 3px;
        color: #fff;
        background: #173d70;
        font-size: 11px;
        font-weight: 720;
        text-align: center;
      }

      td {
        height: auto;
        padding: 0;
        overflow: visible;
        vertical-align: top;
        background: #fff;
        font-size: 9px;
        line-height: 1.24;
        letter-spacing: 0;
      }

      .cell-content {
        display: flex;
        min-width: 0;
        min-height: var(--week-height, 110px);
        height: auto;
        flex-direction: column;
        align-items: stretch;
        gap: 4px;
        padding: 4px 5px 5px;
        overflow: visible;
      }

      td.is-empty { background: #e9eeec !important; }

      .date-line {
        display: inline-flex;
        min-width: 24px;
        min-height: 22px;
        align-items: center;
        align-self: flex-start;
        justify-content: center;
        margin: 0 0 4px;
        padding: 2px 6px;
        border-radius: 4px;
        color: #fff;
        background: #17a6a0;
        font-size: 10px;
        font-weight: 800;
        line-height: 1.15;
      }

      .event-line {
        display: block;
        min-width: 0;
        margin: 0;
        padding: 3px 4px;
        position: relative;
        overflow-wrap: anywhere;
        border-left: 3px solid #6d7c77;
        border-radius: 2px;
        color: #20304f;
        background: #eef3fa;
      }

      .event-line.kind-standard { border-left-color: #004165; background: #c3d7e4; }
      .event-line.kind-private { border-left-color: #7e22ce; background: #f3e8ff; }
      .event-line.kind-online { border-left-color: #db2777; background: #fce7f3; }
      .event-line.kind-tmc { border-left-color: #b91c1c; background: #fee2e2; }

      .event-time {
        display: block;
        color: #526173;
        font-size: 8px;
        font-weight: 800;
        line-height: 1.2;
      }

      .event-title {
        display: block;
        margin-top: 2px;
        font-weight: 750;
        line-height: 1.3;
      }

      .notes-rail {
        min-width: 0;
        border: 1px solid #a0aaa6;
        background: #fff;
      }

      .notes-section + .notes-section { border-top: 1px solid #a0aaa6; }

      .notes-heading {
        margin: 0;
        padding: 7px 9px;
        color: #fff;
        background: #173d70;
        font-size: 11px;
        font-weight: 750;
      }

      .notes-list {
        display: grid;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .note-item {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 6px;
        padding: 6px 8px;
        border-top: 1px solid #d8dddb;
        font-size: 9px;
        line-height: 1.3;
      }

      .note-item:nth-child(odd) { background: #f2f6fb; }

      .note-item:first-child { border-top: 0; }
      .note-label { color: #34413e; }
      .note-value { color: #6a7471; font-weight: 700; }
      .note-item.highlight-travel { border-left: 4px solid #d6a800; background: #fff6cc; }
      .note-item.highlight-holiday { border-left: 4px solid #2e7d32; background: #e8f5e9; }
      .note-item.highlight-makeup { border-left: 4px solid #9aa1a8; background: #eef1f3; }
      .note-item[class*="highlight-"] .note-label,
      .note-item[class*="highlight-"] .note-value { color: #20304f; font-weight: 800; }
      .school-note { display: block; }

      .contact-qr-wrap {
        position: relative;
        width: calc(100% - 20px);
        max-width: 200px;
        aspect-ratio: 1;
        margin: 12px auto 14px;
        overflow: hidden;
        border: 1px solid #d5deed;
        border-radius: 5px;
        background: #fff;
        box-shadow: 0 8px 22px rgb(23 48 78 / 12%);
      }

      .contact-qr {
        position: absolute;
        top: -68.33%;
        left: -28.33%;
        display: block;
        width: 156.33%;
        max-width: none;
        height: auto;
      }

      .status {
        display: grid;
        min-height: 45vh;
        place-items: center;
        padding: 40px 20px;
        text-align: center;
      }

      .status strong { display: block; margin-bottom: 8px; font-size: 18px; }
      .status span { color: #68736f; font-size: 14px; }
      [hidden] { display: none !important; }

      @media (max-width: 900px) {
        .calendar-layout { grid-template-columns: 1fr; }
        .table-shell { overflow-x: auto; }
        table { min-width: 720px; }
        .notes-rail { display: grid; grid-template-columns: 1fr 1fr; }
        .notes-section + .notes-section { border-top: 0; border-left: 1px solid #a0aaa6; }
        .contact-section { grid-column: 1 / -1; border-top: 1px solid #a0aaa6 !important; border-left: 0 !important; }
      }

      @media (max-width: 640px) {
        .coach-banner { aspect-ratio: 1683 / 935; }
        .banner-socials {
          right: 8px;
          bottom: 8px;
          left: 8px;
          justify-content: center;
          gap: 12px;
          padding: 7px 8px;
          font-size: 11px;
        }
        .page-header {
          grid-template-columns: minmax(0, 1fr) 36px;
          gap: 7px 12px;
          min-height: 56px;
          padding: 8px 10px 0;
        }
        .identity h1 { font-size: 16px; }
        .site-nav {
          grid-column: 1 / -1;
          grid-row: 2;
          width: calc(100% + 20px);
          margin-left: -10px;
          gap: 0;
          border-top: 1px solid #e2e8f1;
        }
        .site-nav a {
          flex: 1 1 20%;
          padding: 15px 2px 13px;
          font-size: 14px;
          text-align: center;
        }
        .refresh-button { grid-column: 2; grid-row: 1; }
        main { padding: 8px 0 0; }
        .schedule-toolbar { align-items: center; padding: 0 9px; }
        .month-heading { font-size: 17px; }
        .sheet-tab { padding-right: 9px; padding-left: 9px; }
        .table-shell, .notes-rail { border-right: 0; border-left: 0; }
        .cell-content { min-height: 108px; }
        .notes-rail { grid-template-columns: 1fr; }
        .contact-section { grid-column: auto; }
        .notes-section + .notes-section { border-top: 1px solid #a0aaa6; border-left: 0; }
      }
    </style>
  </head>
  <body>
    <section class="coach-banner" aria-label="Coach Kai social media">
      <picture>
        <source
          media="(max-width: 640px)"
          srcset="/images/coach-kai-banner-mobile.png"
          width="1683"
          height="935"
        />
        <img
          src="/images/coach-kai-banner-desktop.png"
          alt="Coach Kai"
          width="2508"
          height="627"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
      <div class="banner-socials">
        <span>WeChat: <strong>CKcoachkai</strong></span>
        <span>小红书: <strong>CKcoachkai</strong></span>
      </div>
    </section>
    <header class="page-header">
      <div class="identity">
        <h1 id="schedule-title">Coach Kai's Timeslot</h1>
        <p id="updated-time">正在载入 Loading</p>
      </div>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/#about">About</a>
        <a href="/schedule/" aria-current="page">Schedule</a>
        <a href="/tools/">Tools</a>
        <a href="/contact/">Contact</a>
      </nav>
      <button class="refresh-button" type="button" title="Refresh" aria-label="Refresh schedule">
        <RefreshCw size={17} stroke-width={2} aria-hidden="true" />
      </button>
    </header>

    <main>
      <div class="status" id="status" role="status">
        <div><strong>正在载入</strong><span>Loading schedule</span></div>
      </div>
      <section id="schedule" hidden>
        <div class="schedule-toolbar">
          <h2 class="month-heading" id="month-heading"></h2>
          <div class="sheet-tabs" id="sheet-tabs" role="tablist" aria-label="Schedule months"></div>
        </div>
        <div class="calendar-layout">
          <div class="table-shell" id="table-shell"></div>
          <aside class="notes-rail" id="notes-rail" aria-label="Schedule notes"></aside>
        </div>
      </section>
    </main>

    <script>
      type Cell = { value?: string };
      type Sheet = {
        id: number;
        title: string;
        columns: Array<{ hidden?: boolean }>;
        rows: Array<{ hidden?: boolean; cells?: Cell[] }>;
      };
      type ScheduleData = { status: string; updatedAt: string | null; sheets: Sheet[] };

      const statusElement = document.querySelector<HTMLElement>("#status");
      const scheduleElement = document.querySelector<HTMLElement>("#schedule");
      const tabsElement = document.querySelector<HTMLElement>("#sheet-tabs");
      const tableShell = document.querySelector<HTMLElement>("#table-shell");
      const notesRail = document.querySelector<HTMLElement>("#notes-rail");
      const monthHeading = document.querySelector<HTMLElement>("#month-heading");
      const updatedTime = document.querySelector<HTMLElement>("#updated-time");
      const refreshButton = document.querySelector<HTMLButtonElement>(".refresh-button");

      refreshButton?.addEventListener("click", () => window.location.reload());

      function showStatus(title: string, detail: string) {
        if (!statusElement || !scheduleElement) return;
        statusElement.replaceChildren();
        const wrapper = document.createElement("div");
        const strong = document.createElement("strong");
        const span = document.createElement("span");
        strong.textContent = title;
        span.textContent = detail;
        wrapper.append(strong, span);
        statusElement.append(wrapper);
        statusElement.hidden = false;
        scheduleElement.hidden = true;
      }

      function cellValue(sheet: Sheet, row: number, column: number) {
        return (sheet.rows[row]?.cells?.[column]?.value?.trim() ?? "")
          .replaceAll("龙柏", "LB")
          .replaceAll("华漕", "HC");
      }

      function formatEventLine(rawLine: string) {
        let line = rawLine.replaceAll("龙柏", "LB").replaceAll("华漕", "HC").trim();
        const mode = line.includes("线上") ? "线上" : line.includes("线下") ? "线下" : "";
        line = line.replace(/\s*(线上|线下)\s*/g, " ").replace(/\s+/g, " ").trim();

        const separatorIndex = line.indexOf(" - ");
        let main = separatorIndex >= 0 ? line.slice(0, separatorIndex).trim() : line;
        let detail = separatorIndex >= 0 ? line.slice(separatorIndex + 3).trim() : "";
        const inferredMode = mode || (/\b(?:LB|HC|JH)\b/.test(main) ? "线下" : "");
        const shLocationMatch = inferredMode === "\u7ebf\u4e0b" ? main.match(/\b(LB|JH)\b/i) : null;
        const shLocation = shLocationMatch?.[1].toUpperCase() ?? "";
        if (shLocationMatch) {
          main = main.replace(shLocationMatch[0], "").replace(/\s+/g, " ").trim();
        }
        const locationSuffix = inferredMode === "\u7ebf\u4e0b" ? `${shLocation ? ` ${shLocation}` : ""} (SH)` : "";

        if (main.includes("班课")) {
          main = main.replace(/\s*班课\s*/g, " 班课").trim();
          return `${main}${detail ? ` - ${detail}` : ""}${locationSuffix}${inferredMode ? ` ${inferredMode}` : ""}`;
        }

        const lessonMatch = detail.match(/^(Lesson\s+\d+)\s+(.+)$/i);
        const explicitPrivate = detail.match(/^(.+?)\s+1-1$/i);
        const isDescriptor =
          /^(TEDx|备赛|student interview|\u9762\u8bd5|Classes|FBI分享|WSDA国赛)$/i.test(detail) ||
          /All day|Sharing|分享/i.test(main);
        let name = "";

        if (explicitPrivate) {
          name = explicitPrivate[1].trim();
          detail = "";
        } else if (lessonMatch) {
          detail = lessonMatch[1];
          name = lessonMatch[2].trim();
        } else if (detail && !isDescriptor) {
          name = detail;
          detail = "";
        }

        if (name) {
          return `${main} (${name})${detail ? ` - ${detail}` : ""}${locationSuffix}${inferredMode ? ` ${inferredMode}` : ""}`;
        }

        if (/\b1-1\b/i.test(main)) {
          main = main.replace(/\s*1-1\s*/i, " 1-1").trim();
          return `${main}${detail ? ` - ${detail}` : ""}${locationSuffix}${inferredMode ? ` ${inferredMode}` : ""}`;
        }

        return `${main}${detail ? ` - ${detail}` : ""}${locationSuffix}${inferredMode ? ` ${inferredMode}` : ""}`;
      }

      function highlightKind(value: string) {
        if (/\(TMC\)/i.test(value)) return "tmc";
        if (/make-?up workday/i.test(value)) return "makeup";
        if (/holiday/i.test(value)) return "holiday";
        if (/\btravel\b|all day (?:taiwan|thailand)/i.test(value)) return "travel";
        return "";
      }

      function appendLines(cell: HTMLTableCellElement, value: string) {
        const lines = value.split(/\r?\n/).map((line) => line.trim()).filter(Boolean);
        const content = document.createElement("div");
        content.className = "cell-content";
        content.style.cssText =
          "display:flex;min-width:0;min-height:var(--week-height,110px);height:auto;flex-direction:column;align-items:stretch;gap:4px;padding:4px 5px 5px;overflow:visible";
        if (lines.length === 0) {
          cell.classList.add("is-empty");
          cell.append(content);
          return;
        }

        const date = document.createElement("span");
        date.className = "date-line";
        date.textContent = lines[0].replace(/\s*\(\s*\d+(?:\.\d+)?h\s*\)\s*/gi, "").trim();
        date.style.cssText =
          "display:inline-flex;align-self:flex-start;align-items:center;justify-content:center;min-width:24px;min-height:22px;margin:0;padding:2px 6px;border-radius:4px;color:#fff;background:#17a6a0;font-size:10px;font-weight:800;line-height:1.15";
        content.append(date);

        for (const line of lines.slice(1)) {
          const event = document.createElement("span");
          const formattedLine = formatEventLine(line);
          const highlightedKind = highlightKind(formattedLine);
          const hasNamedStudent =
            /\((?!SH\)|TMC\)|Booked\)|Planned\))[^()]+\)/i.test(formattedLine) &&
            /(?:线上|线下)(?:\s|$)/.test(formattedLine);
          const isPrivate = /\b1-1\b/i.test(formattedLine) || hasNamedStudent;
          const kind = highlightedKind || (isPrivate ? "private" : /线上(?:\s|$)/.test(formattedLine) ? "online" : "standard");
          const colors = {
            private: ["#7e22ce", "#f3e8ff"],
            online: ["#db2777", "#fce7f3"],
            standard: ["#004165", "#c3d7e4"],
            tmc: ["#b91c1c", "#fee2e2"],
            travel: ["#d6a800", "#fff6cc"],
            holiday: ["#2e7d32", "#e8f5e9"],
            makeup: ["#9aa1a8", "#eef1f3"],
          }[kind];
          event.className = `event-line kind-${kind}`;
          event.style.cssText = `display:block;position:relative;min-width:0;margin:0;padding:4px 5px;overflow-wrap:anywhere;border-left:3px solid ${colors[0]};border-radius:3px;color:#20304f;background:${colors[1]};font-size:9px;line-height:1.35`;
          const timedEvent = formattedLine.match(/^(\d{1,2}:\d{2}(?:\s*-\s*\d{1,2}:\d{2})?)\s+(.+)$/);
          if (timedEvent) {
            const time = document.createElement("span");
            time.className = "event-time";
            time.textContent = timedEvent[1];
            const title = document.createElement("span");
            title.className = "event-title";
            title.textContent = timedEvent[2];
            event.append(time, title);
          } else {
            event.textContent = formattedLine;
          }
          content.append(event);
        }
        cell.append(content);
      }

      function makeNotesSection(title: string, items: Array<{ label: string; value?: string }>, school = false) {
        const section = document.createElement("section");
        section.className = "notes-section";
        const heading = document.createElement("h3");
        heading.className = "notes-heading";
        heading.textContent = title;
        const list = document.createElement("ul");
        list.className = "notes-list";

        for (const item of items) {
          const li = document.createElement("li");
          const highlight = school ? "" : highlightKind(`${item.label} ${item.value ?? ""}`);
          li.className = `note-item${school ? " school-note" : ""}${highlight ? ` highlight-${highlight}` : ""}`;
          const label = document.createElement("span");
          label.className = "note-label";
          label.textContent = item.label;
          li.append(label);
          if (item.value) {
            const value = document.createElement("span");
            value.className = "note-value";
            value.textContent = item.value;
            li.append(value);
          }
          list.append(li);
        }
        section.append(heading, list);
        return section;
      }

      function makeContactSection() {
        const section = document.createElement("section");
        section.className = "notes-section contact-section";
        const heading = document.createElement("h3");
        heading.className = "notes-heading";
        heading.textContent = "Contact Coach Kai";
        const imageWrap = document.createElement("div");
        imageWrap.className = "contact-qr-wrap";
        const qrImage = document.createElement("img");
        qrImage.className = "contact-qr";
        qrImage.src = "/images/coach-kai-wechat-qr.png";
        qrImage.alt = "WeChat QR code for Coach Kai";
        qrImage.width = 938;
        qrImage.height = 1340;
        qrImage.loading = "eager";
        qrImage.decoding = "async";
        imageWrap.append(qrImage);
        section.append(heading, imageWrap);
        return section;
      }

      function renderSheet(sheet: Sheet) {
        if (!tableShell || !notesRail || !monthHeading) return;
        tableShell.replaceChildren();
        notesRail.replaceChildren();
        monthHeading.textContent = sheet.title;

        const weekdayRow = sheet.rows.findIndex((_, index) =>
          /^Sunday$/i.test(cellValue(sheet, index, 0)),
        );
        if (weekdayRow < 0) {
          showStatus("无法显示此月份", "This month does not contain a calendar grid");
          return;
        }

        const calendarRows = sheet.rows.slice(weekdayRow + 1).filter((row) =>
          row.cells?.slice(0, 7).some((cell) => cell.value?.trim()),
        );
        const availableHeight = Math.max(420, window.innerHeight - 164);
        const weekHeight = Math.min(
          142,
          Math.max(72, Math.floor(availableHeight / Math.max(calendarRows.length, 1))),
        );
        tableShell.style.setProperty("--week-height", `${weekHeight}px`);

        const table = document.createElement("table");
        table.setAttribute("aria-label", `${sheet.title} calendar`);
        table.style.cssText =
          "width:100%;border-collapse:collapse;border-spacing:0;table-layout:fixed;background:#fff";
        const thead = document.createElement("thead");
        const headerRow = document.createElement("tr");
        for (let column = 0; column < 7; column += 1) {
          const th = document.createElement("th");
          th.scope = "col";
          th.textContent = cellValue(sheet, weekdayRow, column);
          th.style.cssText =
            "height:29px;padding:4px 3px;border:1px solid #8da3bf;color:#fff;background:#173d70;font-size:11px;font-weight:720;text-align:center";
          if (column === 0 || column === 6) th.classList.add("is-weekend");
          headerRow.append(th);
        }
        thead.append(headerRow);

        const tbody = document.createElement("tbody");
        for (const row of calendarRows) {
          const tr = document.createElement("tr");
          for (let column = 0; column < 7; column += 1) {
            const td = document.createElement("td");
            td.style.cssText = "height:auto;padding:0;overflow:visible;border:1px solid #9eb0c8;vertical-align:top;background:#fff;font-size:9px;line-height:1.24";
            if (column === 0 || column === 6) td.classList.add("is-weekend");
            appendLines(
              td,
              (row.cells?.[column]?.value ?? "")
                .replaceAll("龙柏", "LB")
                .replaceAll("华漕", "HC"),
            );
            tr.append(td);
          }
          tbody.append(tr);
        }
        table.append(thead, tbody);
        tableShell.append(table);

        const highlights: Array<{ label: string; value?: string }> = [];
        const schoolNotes: Array<{ label: string }> = [];
        for (let row = 1; row < sheet.rows.length; row += 1) {
          const highlightLabel = cellValue(sheet, row, 8);
          const highlightValue = cellValue(sheet, row, 9);
          if (/monthly hours?/i.test(highlightLabel)) continue;
          if (highlightLabel || highlightValue) {
            highlights.push({ label: highlightLabel || highlightValue, value: highlightLabel ? highlightValue : "" });
          }
          const schoolNote = cellValue(sheet, row, 11);
          if (schoolNote) schoolNotes.push({ label: schoolNote });
        }
        if (highlights.length) notesRail.append(makeNotesSection("Day highlights", highlights));
        if (schoolNotes.length) notesRail.append(makeNotesSection("School calendar notes", schoolNotes, true));
        notesRail.append(makeContactSection());
        notesRail.hidden = notesRail.childElementCount === 0;

      }

      function renderSchedule(data: ScheduleData) {
        if (!tabsElement || !scheduleElement || !statusElement || !updatedTime) return;
        if (data.status !== "ready" || data.sheets.length === 0) {
          showStatus("时间表尚未发布", "Schedule setup is not complete");
          updatedTime.textContent = "等待首次同步 Waiting for first sync";
          return;
        }

        updatedTime.textContent = data.updatedAt
          ? `最后更新 Updated ${new Intl.DateTimeFormat(undefined, {
              dateStyle: "medium",
              timeStyle: "short",
            }).format(new Date(data.updatedAt))}`
          : "";

        tabsElement.replaceChildren();
        data.sheets.forEach((sheet, index) => {
          const button = document.createElement("button");
          button.className = "sheet-tab";
          button.type = "button";
          button.role = "tab";
          button.textContent = sheet.title;
          button.ariaSelected = String(index === 0);
          button.addEventListener("click", () => {
            tabsElement.querySelectorAll(".sheet-tab").forEach((tab) => {
              tab.setAttribute("aria-selected", String(tab === button));
            });
            renderSheet(sheet);
          });
          tabsElement.append(button);
        });

        statusElement.hidden = true;
        scheduleElement.hidden = false;
        renderSheet(data.sheets[0]);
      }

      const scheduleDataUrl = ["localhost", "127.0.0.1"].includes(window.location.hostname)
        ? "https://speakkai.com/data/schedule.json"
        : "/data/schedule.json";

      fetch(scheduleDataUrl, { cache: "no-store" })
        .then((response) => {
          if (!response.ok) throw new Error("Schedule data is unavailable.");
          return response.json() as Promise<ScheduleData>;
        })
        .then(renderSchedule)
        .catch(() => {
          showStatus("暂时无法载入时间表", "The schedule could not be loaded");
          if (updatedTime) updatedTime.textContent = "";
        });
    </script>
  </body>
</html>
