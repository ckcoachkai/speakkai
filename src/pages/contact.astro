---
import ContactStrip from "../components/ContactStrip.astro";
import SiteFooter from "../components/SiteFooter.astro";

const pageTitle = "Contact Coach Kai | SpeakKai";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Contact Coach Kai on WeChat or Xiaohongshu."
    />
    <title>{pageTitle}</title>
    <style>
      :global(*) { box-sizing: border-box; }

      :global(html),
      :global(body) {
        min-width: 320px;
        min-height: 100%;
        margin: 0;
      }

      :global(body) {
        background: #f4f8fd;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      .site-header {
        display: flex;
        min-height: 48px;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .site-nav {
        display: flex;
        width: min(100%, 620px);
        align-items: center;
        justify-content: center;
        gap: clamp(18px, 3.5vw, 44px);
      }

      .site-nav a {
        padding: 14px 4px 12px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      @media (max-width: 640px) {
        .site-header { min-height: 46px; }
        .site-nav { width: 100%; gap: 0; }

        .site-nav a {
          flex: 1 1 20%;
          padding: 13px 2px 11px;
          font-size: 13px;
          text-align: center;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/#about">About</a>
        <a href="/schedule/">Schedule</a>
        <a href="/tools/">Tools</a>
        <a href="/contact/" aria-current="page">Contact</a>
      </nav>
    </header>

    <ContactStrip variant="page" />
    <SiteFooter />
  </body>
</html>
