---
import { ArrowRight, Gamepad2 } from "@lucide/astro";
import ContactStrip from "../../components/ContactStrip.astro";

const pageTitle = "Tools | SpeakKai";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Interactive classroom and speaking tools from Coach Kai."
    />
    <title>{pageTitle}</title>
    <style>
      :global(*) { box-sizing: border-box; }

      :global(html) {
        min-width: 320px;
        min-height: 100%;
        background: #f4f7fb;
        color: #14233b;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      :global(body) {
        min-height: 100vh;
        margin: 0;
      }

      .site-header {
        display: flex;
        min-height: 62px;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .site-nav {
        display: flex;
        width: min(100%, 620px);
        align-items: center;
        justify-content: center;
        gap: clamp(18px, 3.5vw, 44px);
      }

      .site-nav a {
        padding: 21px 4px 19px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible,
      .tool-link:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 3px;
      }

      main {
        width: min(100% - 40px, 1120px);
        margin: 0 auto;
        padding: clamp(38px, 6vw, 72px) 0 80px;
      }

      .page-heading {
        display: grid;
        max-width: 680px;
        gap: 10px;
        margin-bottom: 32px;
      }

      .eyebrow {
        color: #087c98;
        font-size: 13px;
        font-weight: 900;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        color: #10284d;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1.05;
        letter-spacing: 0;
      }

      .page-heading p {
        margin: 0;
        color: #52647b;
        font-size: 17px;
        line-height: 1.6;
      }

      .tools-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
      }

      .tool-card {
        overflow: hidden;
        border: 1px solid #cbd7e7;
        border-radius: 8px;
        background: #fff;
        box-shadow: 0 14px 34px rgb(26 55 89 / 10%);
      }

      .tool-preview {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        object-position: center top;
        border-bottom: 1px solid #d7e0ec;
        background: #0b111b;
      }

      .tool-content {
        display: grid;
        gap: 13px;
        padding: 24px;
      }

      .tool-label {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        gap: 7px;
        color: #087c98;
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
      }

      .tool-content h2 {
        margin: 0;
        color: #142b50;
        font-size: 25px;
        line-height: 1.15;
        letter-spacing: 0;
      }

      .tool-content p {
        margin: 0;
        color: #5b6b80;
        font-size: 15px;
        line-height: 1.6;
      }

      .tool-link {
        display: inline-flex;
        width: fit-content;
        min-height: 44px;
        align-items: center;
        gap: 9px;
        margin-top: 3px;
        padding: 11px 16px;
        border-radius: 5px;
        background: #0b68bb;
        color: #fff;
        font-size: 15px;
        font-weight: 850;
        text-decoration: none;
      }

      .tool-link:hover { background: #07589f; }

      @media (max-width: 700px) {
        .site-header { min-height: 52px; }

        .site-nav {
          width: 100%;
          gap: 0;
        }

        .site-nav a {
          flex: 1 1 20%;
          padding: 18px 2px 16px;
          font-size: 14px;
          text-align: center;
        }

        main {
          width: min(100% - 28px, 540px);
          padding-top: 34px;
        }

        .page-heading p { font-size: 16px; }
        .tools-grid { grid-template-columns: 1fr; }
        .tool-content { padding: 20px; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/#about">About</a>
        <a href="/schedule/">Schedule</a>
        <a href="/tools/" aria-current="page">Tools</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>

    <ContactStrip />

    <main>
      <header class="page-heading">
        <span class="eyebrow">Interactive collection</span>
        <h1>SpeakKai Tools</h1>
        <p>Classroom tools for participation, practice, and playful learning.</p>
      </header>

      <section class="tools-grid" aria-label="Available tools">
        <article class="tool-card">
          <img
            class="tool-preview"
            src="/images/marble-name-picker-preview.png"
            width="1280"
            height="720"
            alt="Marble Name Picker physics board preview"
          />
          <div class="tool-content">
            <span class="tool-label">
              <Gamepad2 size={16} stroke-width={2.2} aria-hidden="true" />
              Classroom game
            </span>
            <h2>Marble Name Picker</h2>
            <p>
              Add players, release their marbles, and let the physics board choose
              the next participant.
            </p>
            <a class="tool-link" href="/tools/marble-name-picker/">
              Open tool
              <ArrowRight size={17} stroke-width={2.2} aria-hidden="true" />
            </a>
          </div>
        </article>
      </section>
    </main>
  </body>
</html>
