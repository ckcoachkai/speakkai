---
import { ArrowLeft, CalendarPlus, Clock3, Globe, LockKeyhole, ShieldCheck, Trash2 } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import TopLinks from "@/components/TopLinks.astro";
---

<BaseLayout
  title="Admin Availability | Speaking With Kai"
  description="Admin tools for adding available booking times for Speaking With Kai."
>
  <main>
    <section class="booking-shell admin-shell" aria-labelledby="admin-title">
      <header class="site-nav" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="Speaking With Kai home">SWK</a>
        <nav>
          <a href="/">Home</a>
          <a href="/book/">Book</a>
          <a href="/about-kai/">About Kai</a>
          <a href="/corporate-events/">Corporate Events</a>
        </nav>
        <a class="nav-cta" href="/book/">
          Public page
          <CalendarPlus aria-hidden="true" size={18} />
        </a>
      </header>
      <TopLinks />

      <div class="booking-hero">
        <a class="back-link" href="/book/">
          <ArrowLeft aria-hidden="true" size={18} />
          Booking page
        </a>
        <p class="eyebrow">Admin</p>
        <h1 id="admin-title">Add the times you are free.</h1>
        <p>
          Create open slots, review booked sessions, and keep your public schedule current.
        </p>
      </div>

      <div class="admin-grid">
        <section class="booking-panel" aria-labelledby="admin-access-title">
          <div class="panel-heading">
            <LockKeyhole aria-hidden="true" />
            <div>
              <p class="eyebrow">Access</p>
              <h2 id="admin-access-title">Admin key</h2>
            </div>
          </div>
          <form id="admin-access-form" class="booking-form">
            <label>
              Passcode
              <input id="admin-passcode" type="password" autocomplete="current-password" required />
            </label>
            <button class="button button-light" type="submit">
              Unlock
              <ShieldCheck aria-hidden="true" size={18} />
            </button>
          </form>
          <p class="admin-hint">Temporary local key: <strong>kai-admin</strong></p>
        </section>

        <section class="booking-panel booking-panel-wide is-locked" id="admin-tools" aria-labelledby="add-slot-title">
          <div class="panel-heading">
            <CalendarPlus aria-hidden="true" />
            <div>
              <p class="eyebrow">Availability</p>
              <h2 id="add-slot-title">New open slot</h2>
            </div>
          </div>
          <form id="availability-form" class="booking-form admin-form">
            <label>
              Date
              <input id="slot-date" type="date" required />
            </label>
            <label>
              Start time
              <input id="slot-time" type="time" required />
            </label>
            <label>
              Length
              <select id="slot-duration" required>
                <option value="30">30 min</option>
                <option value="45">45 min</option>
                <option value="60">60 min</option>
              </select>
            </label>
            <label>
              Format
              <select id="slot-mode" required>
                <option value="online">Online</option>
                <option value="in-person">In person</option>
              </select>
            </label>
            <label class="admin-form-full">
              Notes
              <input id="slot-note" placeholder="Parent consult, debate prep, speech coaching" />
            </label>
            <button class="button button-light" type="submit">
              Add time
              <Clock3 aria-hidden="true" size={18} />
            </button>
          </form>
        </section>
      </div>

      <section class="booking-panel admin-list-panel is-locked" id="admin-list-panel" aria-labelledby="admin-list-title">
        <div class="panel-heading">
          <Globe aria-hidden="true" />
          <div>
            <p class="eyebrow">Schedule</p>
            <h2 id="admin-list-title">Current slots and bookings</h2>
          </div>
        </div>
        <div id="admin-slot-list" class="admin-slot-list" aria-live="polite"></div>
        <template id="delete-icon-template">
          <Trash2 aria-hidden="true" size={18} />
        </template>
      </section>
    </section>
  </main>
  <SiteFooter />
  <script is:inline type="module" src="/scripts/admin-booking.js"></script>
</BaseLayout>
