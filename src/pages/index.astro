---
import {
  ArrowUpRight,
  CalendarCheck,
  Camera,
  CircleCheckBig,
  Image as ImageIcon,
  Mail,
  MapPin,
  MessageCircle,
  MicVocal,
  CirclePlay,
  Sparkles,
  Star,
  UsersRound
} from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import TopLinks from "@/components/TopLinks.astro";

const navItems = [
  { href: "/", title: "Home" },
  { href: "#booking-services", title: "Booking Services" },
  { href: "#bio", title: "Bio Introduction" },
  { href: "#portfolio", title: "Portfolio" },
  { href: "#media-pictures", title: "Media Pictures" },
  { href: "#contact", title: "Contact Me" },
  { href: "#videos", title: "Videos" }
];

const bookingServices = [
  {
    number: "01",
    title: "Parent Consultation",
    text: "A focused first conversation to understand goals, needs, and the best next step."
  },
  {
    number: "02",
    title: "Speaking Coaching",
    text: "One-on-one support for clarity, confidence, structure, delivery, and presence."
  },
  {
    number: "03",
    title: "Speech & Debate Prep",
    text: "Practice for students preparing speeches, competitions, interviews, or presentations."
  },
  {
    number: "04",
    title: "Workshops & Events",
    text: "Interactive group sessions, hosting, keynote speaking, and communication workshops."
  }
];

const portfolio = [
  {
    href: "/tongue-twisters/",
    label: "Practice Library",
    title: "Tongue Twisters",
    text: "Clear, playful articulation practice for warmups, family routines, and confident delivery."
  },
  {
    href: "/before-a-competition/",
    label: "Performance Prep",
    title: "Before a Competition",
    text: "A calm routine for students, debaters, presenters, and speakers who need focus."
  },
  {
    href: "/speech-debate-benefits/",
    label: "Student Growth",
    title: "Speech & Debate Benefits",
    text: "A parent-friendly overview of the confidence and communication skills built through speech."
  }
];

const mediaPictures = [
  {
    title: "Speaking portrait",
    text: "Brand photo for SpeakKai coaching, workshops, and media use.",
    image: "/images/kai-portrait.png"
  },
  {
    title: "Workshop moments",
    text: "Add classroom, event, or coaching photos here as the portfolio grows."
  },
  {
    title: "Student practice",
    text: "A space for speech practice, presentation preparation, and parent consultation photos."
  }
];

const videos = [
  {
    title: "Introduction Video",
    text: "A short welcome video can explain who Kai helps and how booking works."
  },
  {
    title: "Speaking Tip",
    text: "Add a practical tip video for pronunciation, confidence, or competition preparation."
  },
  {
    title: "Workshop Clip",
    text: "Use this space for a future event, class, or corporate communication video."
  }
];
---

<BaseLayout
  title="说开表达 SpeakKai | Speaking Coaching and Communication Support"
  description="说开表达 SpeakKai helps students, families, and teams speak with clarity, confidence, and practical next steps."
>
  <main>
    <section class="hero-shell" id="home" aria-labelledby="hero-title">
      <header class="site-nav" aria-label="Primary navigation">
        <a class="brand logo-brand" href="#home" aria-label="说开表达 SpeakKai home">
          <img src="/images/speakkai-logo.png" alt="" />
        </a>
        <nav>
          {navItems.map((item) => <a href={item.href}>{item.title}</a>)}
        </nav>
        <a class="nav-cta" href="/book/">
          Book
          <ArrowUpRight aria-hidden="true" size={18} />
        </a>
      </header>
      <TopLinks />

      <div class="hero-grid">
        <div class="hero-copy">
          <img class="hero-logo-lockup" src="/images/speakkai-logo.png" alt="说开表达 SpeakKai logo" loading="eager" />
          <p class="availability">
            <span></span>
            Booking services now available
          </p>
          <h1 id="hero-title">
            说开表达<br />
            SpeakKai
          </h1>
          <p class="hero-lede">
            SpeakKai helps students, parents, and teams speak clearly, organize ideas,
            and build confident communication habits across English and bilingual contexts.
          </p>
          <div class="hero-actions">
            <a class="button button-light" href="/book/">
              Book a Service
              <CalendarCheck aria-hidden="true" size={18} />
            </a>
            <a class="button button-dark" href="#bio">
              Bio Introduction
              <ArrowUpRight aria-hidden="true" size={18} />
            </a>
          </div>
        </div>

        <aside class="profile-card" aria-label="SpeakKai profile card">
          <div class="profile-logo">
            <img src="/images/speakkai-logo.png" alt="说开表达 SpeakKai logo" loading="lazy" />
          </div>
          <div class="portrait-mark">
            <img
              class="portrait-photo"
              src="/images/kai-portrait.png"
              alt="Kai speaking with one hand raised"
              loading="eager"
            />
          </div>
          <div>
            <h2>说开表达 SpeakKai</h2>
            <p>Speaking coaching, communication support, parent guidance, and workshop facilitation.</p>
          </div>
          <div class="profile-meta">
            <span>
              <MapPin aria-hidden="true" size={16} />
              Online and local support
            </span>
            <span>
              <Sparkles aria-hidden="true" size={16} />
              Practical, warm, bilingual-friendly
            </span>
          </div>
        </aside>
      </div>

      <div class="stats-panel" aria-label="SpeakKai highlights">
        <div>
          <MicVocal aria-hidden="true" />
          <strong>Speech</strong>
          <span>Voice and clarity</span>
        </div>
        <div>
          <UsersRound aria-hidden="true" />
          <strong>Coaching</strong>
          <span>Students and adults</span>
        </div>
        <div>
          <Camera aria-hidden="true" />
          <strong>Media</strong>
          <span>Photos and videos</span>
        </div>
        <div>
          <CalendarCheck aria-hidden="true" />
          <strong>Booking</strong>
          <span>Simple scheduling</span>
        </div>
      </div>
    </section>

    <section class="services-band" id="booking-services" aria-labelledby="booking-services-title">
      <p class="vertical-black">BOOKING SERVICES</p>
      <div class="services-grid">
        {
          bookingServices.map((service) => (
            <article class="service-item">
              <span>{service.number}</span>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
              <CircleCheckBig aria-hidden="true" size={20} />
            </article>
          ))
        }
      </div>
    </section>

    <section class="about-band" id="bio" aria-labelledby="bio-title">
      <div class="vertical-label">BIO</div>
      <div class="about-copy">
        <p class="eyebrow">Bio Introduction</p>
        <h2 id="bio-title">Kai helps people turn thoughts into clear, confident expression.</h2>
        <a class="outline-link" href="/book/">
          Book a consultation
          <ArrowUpRight aria-hidden="true" size={18} />
        </a>
      </div>
      <div class="fact-list">
        <div>
          <span>Name</span>
          <strong>说开表达 SpeakKai</strong>
        </div>
        <div>
          <span>Focus</span>
          <strong>Speaking, confidence, structure, delivery</strong>
        </div>
        <div>
          <span>Audience</span>
          <strong>Students, parents, teams, and event organizers</strong>
        </div>
      </div>
    </section>

    <section class="portfolio-section" id="portfolio" aria-labelledby="portfolio-title">
      <div class="section-heading">
        <p class="vertical-red">PORTFOLIO</p>
        <div>
          <p class="eyebrow">Portfolio</p>
          <h2 id="portfolio-title">Resources, projects, and sample thinking.</h2>
        </div>
      </div>
      <div class="portfolio-grid">
        {
          portfolio.map((item, index) => (
            <article class="work-card">
              <div class="work-visual">
                <span>{String(index + 1).padStart(2, "0")}</span>
                <div class="mini-document">
                  <i />
                  <i />
                  <i />
                </div>
              </div>
              <p>{item.label}</p>
              <h3>{item.title}</h3>
              <span>{item.text}</span>
              <a href={item.href} aria-label={`Read ${item.title}`}>
                <ArrowUpRight aria-hidden="true" size={18} />
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="media-section" id="media-pictures" aria-labelledby="media-title">
      <div class="section-heading">
        <p class="vertical-red">MEDIA PICTURES</p>
        <div>
          <p class="eyebrow">Media Pictures</p>
          <h2 id="media-title">Photos for coaching, workshops, and speaking moments.</h2>
        </div>
      </div>
      <div class="media-grid">
        {
          mediaPictures.map((item, index) => (
            <article class="photo-card">
              <div class={item.image ? "photo-frame" : "photo-frame empty-photo"}>
                {item.image ? (
                  <img src={item.image} alt={item.title} loading={index === 0 ? "eager" : "lazy"} />
                ) : (
                  <ImageIcon aria-hidden="true" />
                )}
              </div>
              <p>{String(index + 1).padStart(2, "0")}</p>
              <h3>{item.title}</h3>
              <span>{item.text}</span>
            </article>
          ))
        }
      </div>
    </section>

    <section class="contact-section" id="contact" aria-labelledby="contact-title">
      <p class="vertical-label light">CONTACT ME</p>
      <div>
        <p class="eyebrow">Contact Me</p>
        <h2 id="contact-title">Ready to talk about speaking support?</h2>
      </div>
      <div class="contact-panel">
        <a href="/book/">
          <CalendarCheck aria-hidden="true" />
          Book an available time
        </a>
        <a href="mailto:hello@speakkai.com">
          <Mail aria-hidden="true" />
          hello@speakkai.com
        </a>
        <a href="/corporate-events/">
          <MessageCircle aria-hidden="true" />
          Ask about workshops or events
        </a>
        <a class="orb-button" href="mailto:hello@speakkai.com" aria-label="Email SpeakKai">
          <Star aria-hidden="true" />
        </a>
      </div>
    </section>

    <section class="video-section" id="videos" aria-labelledby="videos-title">
      <div class="section-heading video-heading">
        <p class="vertical-red">VIDEOS</p>
        <div>
          <p class="eyebrow">Videos</p>
          <h2 id="videos-title">A place for SpeakKai clips, tips, and introductions.</h2>
        </div>
      </div>
      <div class="video-grid">
        {
          videos.map((video, index) => (
            <article class="video-card home-video-card">
              <div class="video-placeholder">
                <CirclePlay aria-hidden="true" />
                <span>{String(index + 1).padStart(2, "0")}</span>
              </div>
              <h3>{video.title}</h3>
              <p>{video.text}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
