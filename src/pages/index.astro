---
import ContactStrip from "../components/ContactStrip.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <meta name="description" content="Coach Kai's schedule and WeChat contact." />
    <title>SpeakKai | Coach Kai</title>
    <style>
      :root {
        color-scheme: light;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background: #f5f7fa;
        color: #071b3d;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
        margin: 0;
      }

      body {
        background: #f5f7fa;
      }

      main {
        min-height: 100vh;
      }

      .coach-banner {
        position: relative;
        width: 100%;
        aspect-ratio: 4 / 1;
        overflow: hidden;
        background: #020b20;
      }

      .coach-banner picture,
      .coach-banner img {
        display: block;
        width: 100%;
        height: 100%;
      }

      .coach-banner img {
        object-fit: contain;
      }

      .site-header {
        display: flex;
        min-height: 62px;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .site-nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: clamp(22px, 4vw, 52px);
      }

      .site-nav a {
        padding: 21px 4px 19px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 16px;
        font-weight: 800;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      .home-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        width: min(100% - 40px, 640px);
        margin: 0 auto;
        padding: 52px 0 64px;
      }

      .schedule-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: min(100%, 360px);
        min-height: 72px;
        padding: 18px 28px;
        border: 2px solid #0b5fc7;
        border-radius: 6px;
        background: #0b5fc7;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.2;
        text-align: center;
        text-decoration: none;
        transition:
          background-color 160ms ease,
          border-color 160ms ease,
          transform 160ms ease;
      }

      .schedule-link:hover {
        border-color: #074a9f;
        background: #074a9f;
        transform: translateY(-2px);
      }

      .schedule-link:focus-visible {
        outline: 3px solid #ffbf47;
        outline-offset: 4px;
      }

      @media (max-width: 640px) {
        .coach-banner {
          aspect-ratio: 1683 / 935;
        }

        .site-header {
          min-height: 52px;
        }

        .site-nav {
          width: 100%;
          gap: 0;
        }

        .site-nav a {
          flex: 1 1 20%;
          padding: 18px 2px 16px;
          font-size: 14px;
          text-align: center;
        }

        .home-actions {
          width: min(100% - 32px, 420px);
          padding: 32px 0 44px;
        }

        .schedule-link {
          min-height: 64px;
          font-size: 1.25rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .schedule-link {
          transition: none;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="coach-banner" id="about" aria-label="Coach Kai social media">
        <picture>
          <source
            media="(max-width: 640px)"
            srcset="/images/coach-kai-banner-mobile.png"
          />
          <img
            src="/images/coach-kai-banner-desktop.png"
            width="2508"
            height="627"
            alt="Coach Kai"
          />
        </picture>
      </section>

      <header class="site-header">
        <nav class="site-nav" aria-label="Main navigation">
          <a href="/" aria-current="page">Home</a>
          <a href="/#about">About</a>
          <a href="/schedule/">Schedule</a>
          <a href="/tools/">Tools</a>
          <a href="/#contact">Contact</a>
        </nav>
      </header>

      <ContactStrip id="contact" />

      <section class="home-actions" aria-label="Schedule">
        <a class="schedule-link" href="/schedule/">Schedule</a>
      </section>
    </main>
  </body>
</html>
