---
import "../styles/global.css";

const offerings = [
  {
    title: "Speaking Clarity",
    body: "Shape ideas into talks, lessons, and interviews that land quickly and sound natural.",
  },
  {
    title: "English Practice",
    body: "Build fluency through focused sessions for pronunciation, pacing, and confident replies.",
  },
  {
    title: "Content Coaching",
    body: "Turn rough notes into scripts, outlines, and repeatable communication systems.",
  },
];

const steps = [
  "Pick the communication goal",
  "Practice with direct feedback",
  "Leave with phrases you can reuse",
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="SpeakKai helps you practice clear, confident speaking for work, study, and public communication." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>SpeakKai | Clear, Confident Speaking</title>
  </head>
  <body>
    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero__media" aria-hidden="true">
          <img src="https://images.unsplash.com/photo-1683234326324-10d082893ec1?auto=format&fit=crop&fm=jpg&ixlib=rb-4.1.0&q=80&w=2400" alt="" />
        </div>
        <div class="hero__content">
          <p class="eyebrow">Speaking coaching</p>
          <h1 id="hero-title">SpeakKai</h1>
          <p class="hero__lead">
            Clear, confident speaking practice for people who want to sound prepared, natural, and sharp in English.
          </p>
          <div class="hero__actions">
            <a class="button button--primary" href="mailto:hello@speakkai.com">Book a session</a>
            <a class="button button--secondary" href="#work">See the approach</a>
          </div>
        </div>
      </section>

      <section class="section intro" id="work" aria-labelledby="work-title">
        <div>
          <p class="section__label">What we work on</p>
          <h2 id="work-title">Speaking practice that stays close to real life.</h2>
        </div>
        <p>
          SpeakKai is built for practical communication: presentations, interviews, study, client calls,
          creator scripts, and everyday conversations where clarity matters more than memorizing rules.
        </p>
      </section>

      <section class="offerings" aria-label="Services">
        {offerings.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </section>

      <section class="section process" aria-labelledby="process-title">
        <div>
          <p class="section__label">Method</p>
          <h2 id="process-title">Simple sessions, useful takeaways.</h2>
        </div>
        <ol>
          {steps.map((step) => <li>{step}</li>)}
        </ol>
      </section>

      <section class="cta" aria-labelledby="cta-title">
        <p class="section__label">Start</p>
        <h2 id="cta-title">Bring one speaking goal. Leave with a clearer version.</h2>
        <a class="button button--primary" href="mailto:hello@speakkai.com">hello@speakkai.com</a>
      </section>
    </main>
  </body>
</html>
