---
import { ArrowRight } from "@lucide/astro";
import ResourceLayout from "../../../layouts/ResourceLayout.astro";
---

<ResourceLayout
  pageTitle="Slides | SpeakKai Resources"
  description="Coach Kai's presentation materials for speaking practice."
>
  <header class="page-heading">
    <span class="eyebrow">Practice materials</span>
    <h1>Slides Page</h1>
    <p>Presentation materials for expressive, confident communication.</p>
  </header>

  <article class="resource-card">
    <img
      class="resource-visual"
      src="/images/emotional-expression-practice-preview.png"
      width="1280"
      height="720"
      alt="Slide from Emotional Expression Practice showing Coach Kai smiling beside a happy-expression example"
    />
    <div class="resource-content">
      <span>Expression practice</span>
      <h2>Emotional Expression Practice</h2>
      <p>Explore vocal and physical expression through Coach Kai's interactive presentation.</p>
      <a href="/resources/emotional-expression-practice/">
        View slides
        <ArrowRight size={18} stroke-width={2.2} aria-hidden="true" />
      </a>
    </div>
  </article>

  <style>
    .page-heading { display: grid; max-width: 720px; gap: 10px; margin-bottom: 38px; }
    .eyebrow, .resource-content span { color: #087c98; font-size: 13px; font-weight: 900; letter-spacing: 0; text-transform: uppercase; }
    h1, h2 { margin: 0; color: #10284d; letter-spacing: 0; }
    h1 { font-size: clamp(36px, 5vw, 54px); line-height: 1.05; }
    h2 { font-size: clamp(26px, 3.6vw, 36px); line-height: 1.1; }
    .page-heading p, .resource-content p { margin: 0; color: #52647b; font-size: 17px; line-height: 1.6; }
    .resource-content p { font-size: 16px; }
    .resource-card { display: grid; grid-template-columns: minmax(260px, 1fr) minmax(0, 1fr); overflow: hidden; border: 1px solid #cbd7e7; border-radius: 8px; background: #fff; box-shadow: 0 14px 34px rgb(26 55 89 / 10%); }
    .resource-visual { display: block; width: 100%; height: 100%; min-height: 260px; object-fit: cover; object-position: center top; border-right: 1px solid #c7d9e8; background: #eaf5f7; }
    .resource-content { display: grid; align-content: center; justify-items: start; gap: 14px; padding: clamp(24px, 4vw, 42px); }
    .resource-content a { display: inline-flex; width: fit-content; min-height: 44px; align-items: center; gap: 9px; margin-top: 4px; padding: 11px 16px; border-radius: 5px; background: #0b68bb; color: #fff; font-size: 15px; font-weight: 850; text-decoration: none; }
    .resource-content a:hover { background: #07589f; }
    .resource-content a:focus-visible { outline: 3px solid #80d6d1; outline-offset: 3px; }
    @media (max-width: 680px) { .resource-card { grid-template-columns: 1fr; } .resource-visual { min-height: 0; aspect-ratio: 16 / 9; border-right: 0; border-bottom: 1px solid #c7d9e8; } .resource-content { padding: 24px; } .page-heading p { font-size: 16px; } }
  </style>
</ResourceLayout>
