---
import ToolsGallery from "../../../components/ToolsGallery.astro";
import ResourceLayout from "../../../layouts/ResourceLayout.astro";
---

<ResourceLayout
  pageTitle="Tools | SpeakKai Resources"
  description="Interactive classroom and speaking tools from Coach Kai."
>
  <header class="page-heading">
    <span class="eyebrow">Interactive collection</span>
    <h1>Tools Page</h1>
    <p>Classroom tools for participation, practice, and playful learning.</p>
  </header>

  <ToolsGallery />

  <style>
    .page-heading { display: grid; max-width: 720px; gap: 10px; margin-bottom: 34px; }
    .eyebrow { color: #087c98; font-size: 13px; font-weight: 900; letter-spacing: 0; text-transform: uppercase; }
    h1 { margin: 0; color: #10284d; font-size: clamp(36px, 5vw, 54px); line-height: 1.05; letter-spacing: 0; }
    p { margin: 0; color: #52647b; font-size: 17px; line-height: 1.6; }
    @media (max-width: 680px) { p { font-size: 16px; } }
  </style>
</ResourceLayout>
