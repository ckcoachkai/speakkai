---
import { ArrowRight, Presentation, Wrench } from "@lucide/astro";
import ResourceLayout from "../../layouts/ResourceLayout.astro";
---

<ResourceLayout
  pageTitle="Resources | SpeakKai"
  description="Coach Kai's slides and interactive speaking tools."
>
  <header class="page-heading">
    <span class="eyebrow">Learning library</span>
    <h1>Resources</h1>
    <p>Choose slides for guided practice, or tools for classroom activities.</p>
  </header>

  <section class="resource-choices" aria-label="Resource categories">
    <article class="choice-card">
      <img
        src="/images/emotional-expression-practice-preview.png"
        width="1280"
        height="720"
        alt="Coach Kai's Emotional Expression Practice slide"
      />
      <div class="choice-content">
        <span><Presentation size={17} stroke-width={2.2} aria-hidden="true" /> Practice materials</span>
        <h2>Slides Page</h2>
        <p>Explore Coach Kai's presentation materials and speaking exercises.</p>
        <a href="/resources/slides/">View slides <ArrowRight size={18} stroke-width={2.2} aria-hidden="true" /></a>
      </div>
    </article>

    <article class="choice-card">
      <img
        src="/images/marble-name-picker-preview.png"
        width="1280"
        height="720"
        alt="Marble Name Picker classroom tool preview"
      />
      <div class="choice-content">
        <span><Wrench size={17} stroke-width={2.2} aria-hidden="true" /> Interactive collection</span>
        <h2>Tools Page</h2>
        <p>Open games, timers, and classroom tools for lively practice.</p>
        <a href="/resources/tools/">View tools <ArrowRight size={18} stroke-width={2.2} aria-hidden="true" /></a>
      </div>
    </article>
  </section>

  <style>
    .page-heading { display: grid; max-width: 720px; gap: 10px; margin-bottom: 38px; }
    .eyebrow, .choice-content span { color: #087c98; font-size: 13px; font-weight: 900; letter-spacing: 0; text-transform: uppercase; }
    h1, h2 { margin: 0; color: #10284d; letter-spacing: 0; }
    h1 { font-size: clamp(36px, 5vw, 54px); line-height: 1.05; }
    h2 { font-size: clamp(28px, 3vw, 35px); line-height: 1.1; }
    .page-heading p, .choice-content p { margin: 0; color: #52647b; font-size: 17px; line-height: 1.6; }
    .choice-content p { font-size: 16px; }
    .resource-choices { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 22px; }
    .choice-card { overflow: hidden; border: 1px solid #cbd7e7; border-radius: 8px; background: #fff; box-shadow: 0 14px 34px rgb(26 55 89 / 10%); }
    .choice-card img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; object-position: center top; border-bottom: 1px solid #d7e0ec; }
    .choice-content { display: grid; align-content: start; justify-items: start; gap: 14px; padding: clamp(24px, 4vw, 32px); }
    .choice-content span { display: inline-flex; width: fit-content; align-items: center; gap: 7px; font-size: 12px; }
    .choice-content a { display: inline-flex; width: fit-content; min-height: 44px; align-items: center; gap: 9px; margin-top: 4px; padding: 11px 16px; border-radius: 5px; background: #0b68bb; color: #fff; font-size: 15px; font-weight: 850; text-decoration: none; }
    .choice-content a:hover { background: #07589f; }
    .choice-content a:focus-visible { outline: 3px solid #80d6d1; outline-offset: 3px; }
    @media (max-width: 720px) { .resource-choices { grid-template-columns: 1fr; } .page-heading p { font-size: 16px; } }
  </style>
</ResourceLayout>
