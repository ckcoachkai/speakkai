---
import { ArrowRight, Disc3, Drama, Gamepad2, Swords, Timer } from "@lucide/astro";
import ResourceLayout from "../../layouts/ResourceLayout.astro";

const tools = [
  {
    name: "Marble Name Picker",
    description: "Release player marbles and let the physics board choose the next participant.",
    href: "/tools/marble-name-picker/",
    image: "/images/marble-name-picker-preview.png",
    imageAlt: "Marble Name Picker physics board preview",
    label: "Classroom game",
    icon: Gamepad2,
  },
  {
    name: "Class Charades",
    description: "Run fast-paced charades rounds with prompts, a timer, and live team scoring.",
    href: "/tools/class-charades/",
    image: "/images/class-charades-preview.png",
    imageAlt: "Class Charades game arena preview",
    label: "Classroom game",
    icon: Drama,
  },
  {
    name: "Toastmasters Speech Timer",
    description: "Time speeches, evaluations, and Table Topics with clear timing signals.",
    href: "/tools/toastmasters-timer/",
    image: "/images/toastmasters-timer-preview.png",
    imageAlt: "Toastmasters Speech Timer preview",
    label: "Speaking tool",
    icon: Timer,
  },
  {
    name: "Wheel of Doom",
    description: "Choose the next participant with a colorful, customizable random wheel.",
    href: "/tools/wheel-of-doom/",
    image: "/images/wheel-of-doom-preview.png",
    imageAlt: "Wheel of Doom random name picker preview",
    label: "Classroom game",
    icon: Disc3,
  },
  {
    name: "Speech & Debate Timer",
    description: "Competition and classroom timing for speech and debate events.",
    href: "/tools/speech-debate-timer/",
    image: "/images/speech-debate-timer-preview.png",
    imageAlt: "Student Speech and Debate Timer preview",
    label: "Competition tool",
    icon: Swords,
  },
];
---

<ResourceLayout
  pageTitle="Resources | SpeakKai"
  description="Speaking practice resources and interactive classroom tools from Coach Kai."
>
  <header class="page-heading">
    <span class="eyebrow">Learning library</span>
    <h1>Resources</h1>
    <p>Practice materials and interactive tools for expressive, confident communication.</p>
  </header>

  <section class="featured-section" aria-labelledby="practice-heading">
    <div class="section-heading">
      <span class="eyebrow">Practice resource</span>
      <h2 id="practice-heading">Emotional Expression Practice</h2>
    </div>

    <article class="resource-card">
      <img
        class="resource-visual"
        src="/images/emotional-expression-practice-preview.png"
        width="1280"
        height="720"
        alt="Slide from Emotional Expression Practice showing Coach Kai smiling beside a happy-expression example"
      />
      <div class="resource-content">
        <span class="resource-type">Expression practice</span>
        <h3>Emotional Expression Practice</h3>
        <p>Explore vocal and physical expression through Coach Kai's interactive presentation.</p>
        <a class="resource-link" href="/resources/emotional-expression-practice/">
          View resource
          <ArrowRight size={18} stroke-width={2.2} aria-hidden="true" />
        </a>
      </div>
    </article>
  </section>

  <section class="tools-section" aria-labelledby="tools-heading">
    <div class="section-heading">
      <span class="eyebrow">Interactive collection</span>
      <h2 id="tools-heading">Tools</h2>
    </div>

    <div class="tools-grid" aria-label="Available tools">
      {tools.map((tool) => {
        const Icon = tool.icon;
        return (
          <article class="tool-card">
            <img
              class="tool-preview"
              src={tool.image}
              width="1280"
              height="720"
              alt={tool.imageAlt}
            />
            <div class="tool-content">
              <span class="tool-label">
                <Icon size={16} stroke-width={2.2} aria-hidden="true" />
                {tool.label}
              </span>
              <h3>{tool.name}</h3>
              <p>{tool.description}</p>
              <a class="tool-link" href={tool.href}>
                Open tool
                <ArrowRight size={17} stroke-width={2.2} aria-hidden="true" />
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <style>
    .page-heading,
    .section-heading {
      display: grid;
      gap: 10px;
    }

    .page-heading {
      max-width: 720px;
      margin-bottom: 38px;
    }

    .eyebrow,
    .resource-type,
    .tool-label {
      color: #087c98;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1,
    h2,
    h3 {
      margin: 0;
      color: #10284d;
      letter-spacing: 0;
    }

    h1 {
      font-size: clamp(36px, 5vw, 54px);
      line-height: 1.05;
    }

    h2 {
      font-size: clamp(27px, 4vw, 36px);
      line-height: 1.12;
    }

    .page-heading p,
    .resource-content p,
    .tool-content p {
      margin: 0;
      color: #52647b;
      font-size: 16px;
      line-height: 1.6;
    }

    .page-heading p { font-size: 17px; }

    .featured-section,
    .tools-section {
      display: grid;
      gap: 18px;
    }

    .tools-section { margin-top: 52px; }

    .resource-card,
    .tool-card {
      overflow: hidden;
      border: 1px solid #cbd7e7;
      border-radius: 8px;
      background: #fff;
      box-shadow: 0 14px 34px rgb(26 55 89 / 10%);
    }

    .resource-card {
      display: grid;
      grid-template-columns: minmax(260px, 1fr) minmax(0, 1fr);
    }

    .resource-visual {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 260px;
      object-fit: cover;
      object-position: center top;
      border-right: 1px solid #c7d9e8;
      background: #eaf5f7;
    }

    .resource-content,
    .tool-content {
      display: grid;
      align-content: start;
      justify-items: start;
      gap: 13px;
    }

    .resource-content { padding: clamp(24px, 4vw, 42px); }

    .resource-content h3 { font-size: clamp(26px, 3.6vw, 36px); line-height: 1.1; }

    .resource-link,
    .tool-link {
      display: inline-flex;
      width: fit-content;
      min-height: 44px;
      align-items: center;
      gap: 9px;
      margin-top: 4px;
      padding: 11px 16px;
      border-radius: 5px;
      background: #0b68bb;
      color: #fff;
      font-size: 15px;
      font-weight: 850;
      text-decoration: none;
    }

    .resource-link:hover,
    .tool-link:hover { background: #07589f; }

    .resource-link:focus-visible,
    .tool-link:focus-visible { outline: 3px solid #80d6d1; outline-offset: 3px; }

    .tools-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
    }

    .tool-preview {
      display: block;
      width: 100%;
      height: 190px;
      object-fit: cover;
      object-position: center top;
      border-bottom: 1px solid #d7e0ec;
      background: #0b111b;
    }

    .tool-content { padding: 20px; }

    .tool-label {
      display: inline-flex;
      width: fit-content;
      align-items: center;
      gap: 7px;
      font-size: 12px;
    }

    .tool-content h3 { color: #142b50; font-size: 23px; line-height: 1.15; }

    .tool-content p { font-size: 15px; }

    @media (max-width: 920px) {
      .tools-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 680px) {
      .resource-card { grid-template-columns: 1fr; }
      .resource-visual {
        min-height: 0;
        aspect-ratio: 16 / 9;
        border-right: 0;
        border-bottom: 1px solid #c7d9e8;
      }
      .resource-content { padding: 24px; }
      .tools-section { margin-top: 40px; }
      .tools-grid { grid-template-columns: 1fr; }
      .tool-preview { height: clamp(150px, 42vw, 175px); }
      .page-heading p { font-size: 16px; }
    }
  </style>
</ResourceLayout>
