---
import { ArrowRight, Presentation } from "@lucide/astro";
import ResourceLayout from "../../layouts/ResourceLayout.astro";
---

<ResourceLayout
  pageTitle="Resources | SpeakKai"
  description="Speaking and emotional expression practice resources from Coach Kai."
>
  <header class="page-heading">
    <span class="eyebrow">Learning library</span>
    <h1>Resources</h1>
    <p>Practice materials for expressive, confident communication.</p>
  </header>

  <section class="resource-list" aria-label="Available resources">
    <article class="resource-card">
      <div class="resource-visual" aria-hidden="true">
        <Presentation size={54} stroke-width={1.7} />
        <span>Practice deck</span>
      </div>
      <div class="resource-content">
        <span class="resource-type">Expression practice</span>
        <h2>Emotional Expression Practice</h2>
        <p>Explore vocal and physical expression through Coach Kai's interactive presentation.</p>
        <a class="resource-link" href="/resources/emotional-expression-practice/">
          View resource
          <ArrowRight size={18} stroke-width={2.2} aria-hidden="true" />
        </a>
      </div>
    </article>
  </section>

  <style>
    .page-heading {
      display: grid;
      max-width: 680px;
      gap: 10px;
      margin-bottom: 32px;
    }

    .eyebrow,
    .resource-type {
      color: #087c98;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      color: #10284d;
      font-size: clamp(36px, 5vw, 54px);
      line-height: 1.05;
      letter-spacing: 0;
    }

    .page-heading p,
    .resource-content p {
      margin: 0;
      color: #52647b;
      font-size: 17px;
      line-height: 1.6;
    }

    .resource-list { max-width: 820px; }

    .resource-card {
      display: grid;
      grid-template-columns: minmax(210px, 0.75fr) minmax(0, 1.25fr);
      overflow: hidden;
      border: 1px solid #cbd7e7;
      border-radius: 8px;
      background: #fff;
      box-shadow: 0 14px 34px rgb(26 55 89 / 10%);
    }

    .resource-visual {
      display: grid;
      min-height: 270px;
      place-content: center;
      gap: 14px;
      border-right: 1px solid #c7d9e8;
      background: #eaf5f7;
      color: #0a6885;
      text-align: center;
    }

    .resource-visual span {
      font-size: 13px;
      font-weight: 900;
      text-transform: uppercase;
    }

    .resource-content {
      display: grid;
      align-content: center;
      justify-items: start;
      gap: 14px;
      padding: clamp(24px, 5vw, 42px);
    }

    .resource-content h2 {
      margin: 0;
      color: #142b50;
      font-size: clamp(26px, 4vw, 36px);
      line-height: 1.1;
      letter-spacing: 0;
    }

    .resource-content p { font-size: 16px; }

    .resource-link {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      gap: 9px;
      margin-top: 4px;
      padding: 11px 16px;
      border-radius: 5px;
      background: #0b68bb;
      color: #fff;
      font-size: 15px;
      font-weight: 850;
      text-decoration: none;
    }

    .resource-link:hover { background: #07589f; }
    .resource-link:focus-visible { outline: 3px solid #80d6d1; outline-offset: 3px; }

    @media (max-width: 680px) {
      .resource-card { grid-template-columns: 1fr; }
      .resource-visual {
        min-height: 170px;
        border-right: 0;
        border-bottom: 1px solid #c7d9e8;
      }
      .resource-content { padding: 24px; }
      .page-heading p { font-size: 16px; }
    }
  </style>
</ResourceLayout>
