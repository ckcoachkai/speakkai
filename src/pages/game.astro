---
const pageTitle = "Gravity Marble Name Picker | SpeakKai";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Play Coach Kai's classroom gravity marble name picker."
    />
    <title>{pageTitle}</title>
    <style>
      :global(*) {
        box-sizing: border-box;
      }

      :global(html),
      :global(body) {
        width: 100%;
        min-width: 320px;
        height: 100%;
        margin: 0;
      }

      :global(body) {
        overflow: hidden;
        background: #090d14;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      .site-header {
        position: relative;
        z-index: 10;
        display: flex;
        min-height: 56px;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid #d5deed;
        background: #fff;
      }

      .site-nav {
        display: flex;
        width: min(100%, 620px);
        align-items: center;
        justify-content: center;
        gap: clamp(18px, 3.5vw, 44px);
      }

      .site-nav a {
        padding: 19px 2px 17px;
        border-bottom: 2px solid transparent;
        color: #294568;
        font-size: 13px;
        font-weight: 700;
        line-height: 1;
        text-decoration: none;
      }

      .site-nav a:hover,
      .site-nav a[aria-current="page"] {
        border-bottom-color: #19a9c5;
        color: #0a5f91;
      }

      .site-nav a:focus-visible {
        border-radius: 3px;
        outline: 3px solid #80d6d1;
        outline-offset: 2px;
      }

      .game-frame {
        display: block;
        width: 100%;
        height: calc(100vh - 56px);
        height: calc(100dvh - 56px);
        border: 0;
        background: #090d14;
      }

      @media (max-width: 640px) {
        .site-header {
          min-height: 48px;
        }

        .site-nav {
          width: 100%;
          gap: 0;
        }

        .site-nav a {
          flex: 1 1 20%;
          padding: 16px 2px 14px;
          font-size: 12px;
          text-align: center;
        }

        .game-frame {
          height: calc(100vh - 48px);
          height: calc(100dvh - 48px);
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/">Home</a>
        <a href="/#about">About</a>
        <a href="/schedule/">Schedule</a>
        <a href="/game/" aria-current="page">Game</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>
    <iframe
      class="game-frame"
      src="/games/marble-name-picker.html"
      title="Gravity Marble Name Picker"
      allow="autoplay"
    ></iframe>
  </body>
</html>
